# XMedia deployment configuration — copy to `.env` and edit before first boot.
#
# Required: POSTGRES_PASSWORD, XMEDIA_VAULT_PASSPHRASE, XMEDIA_BOOTSTRAP_ADMIN_PASSWORD.
# Once the admin has logged in and rotated the password, you can unset the
# bootstrap variables — the server only consults them when the users table
# is empty, so leaving them set is safe but no longer necessary.
#
# NOTE: This template is for PRODUCTION Docker Compose deploys.
# For local development, see `.env.dev` (postgres on 5432, password xmedia_dev).

# ---------------------------------------------------------------------------
# Image and ports
# ---------------------------------------------------------------------------
# Pin a specific release for reproducible deploys, e.g. ghcr.io/secur8yai/xmedia:v0.6.0.
XMEDIA_IMAGE=ghcr.io/secur8yai/xmedia:latest
# Host port the UI/API is exposed on. Container always listens on 8000 internally.
# Conventional defaults: 8000 (dev parity) or 8080 (prod alt-HTTP). Pick one
# and keep it consistent across compose, reverse proxy, and firewall rules.
XMEDIA_HTTP_HOST_PORT=8080

# ---------------------------------------------------------------------------
# Data and config paths (bind-mounted into the container)
# ---------------------------------------------------------------------------
# Host directories mounted as /data and /config inside the container.
# The install script creates /data by default. Override to use a custom path.
XMEDIA_DATA=/data
XMEDIA_CONFIG=/config

# ---------------------------------------------------------------------------
# PostgreSQL credentials (used by the bundled `postgres` service)
# ---------------------------------------------------------------------------
POSTGRES_USER=xmedia
# CHANGE THIS before exposing the port to anything that isn't localhost.
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=xmedia

# ---------------------------------------------------------------------------
# Vault (encrypts all stored API keys and credentials)
# ---------------------------------------------------------------------------
# LOSING THIS PASSPHRASE PERMANENTLY LOCKS EVERY STORED CREDENTIAL.
# Back it up in a password manager before first boot.
XMEDIA_VAULT_PASSPHRASE=generate-a-long-random-passphrase-and-keep-it-safe

# Argon2id cost knobs — the defaults preserve v0.7.x compatibility (64 GiB
# memory) which is unusable on most dev machines (multi-minute boot hang on
# anything <64 GB RAM). Set the memory cost to OWASP's recommendation
# (64 MiB) for dev. PRODUCTION OPERATORS: do not lower the memory cost on a
# vault that was sealed at the higher cost — re-derivation will not produce
# the same key and every stored credential will become undecryptable.
# Re-seal explicitly via the vault rotation flow before lowering this.
# XMEDIA_VAULT_ARGON2_MEMORY_KIB=65536    # 64 MiB — OWASP recommended for new installs
# XMEDIA_VAULT_ARGON2_TIME=3              # iterations, OWASP recommendation
# XMEDIA_VAULT_ARGON2_THREADS=4           # parallelism, OWASP recommendation

# ---------------------------------------------------------------------------
# First-run admin bootstrap
# ---------------------------------------------------------------------------
# When the users table is empty on boot, the server seeds this admin account,
# then logs a warning asking you to remove the password variable. The block
# is a no-op on every subsequent boot.
XMEDIA_BOOTSTRAP_ADMIN_USERNAME=admin
XMEDIA_BOOTSTRAP_ADMIN_PASSWORD=pick-a-strong-initial-password
# Optional display name:
# XMEDIA_BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator

# ---------------------------------------------------------------------------
# Library metadata sidecars
# ---------------------------------------------------------------------------
# Format used for the .nfo / tvshow.nfo files emitted alongside imported
# media. "kodi" (default) is consumed unchanged by Plex, Jellyfin, Emby, and
# Kodi. Set to "none" to disable sidecar emission entirely.
XMEDIA_LIBRARY_METADATA_FORMAT=kodi

# ---------------------------------------------------------------------------
# Licensing — REQUIRED for production
# ---------------------------------------------------------------------------
# XMedia is licensed commercial software. There is no trial — obtain a key
# from the vendor before installing. The key is an Ed25519-signed token
# tied to your customer ID, validated offline at every boot.
#
# In XMEDIA_PROFILE=production:
#   - Missing or invalid key → fatal boot exit.
#   - Revoked customer ID (see revocation list below) → fatal boot exit
#     within ~7 days of revocation.
#
# In dev profile (no XMEDIA_PROFILE set), missing/invalid keys log a warning
# and the server continues, so feature development isn't blocked.
XMEDIA_LICENSE_KEY=

# URL where the binary fetches the signed revocation list once a day.
# Default is the vendor's public file at
# https://raw.githubusercontent.com/secur8yai/xmedia-revoked/main/revoked.json.
# Override only if you host your own signed list (advanced).
# XMEDIA_LICENSE_REVOKED_URL=https://...

# ---------------------------------------------------------------------------
# Optional hardening
# ---------------------------------------------------------------------------
# Uncomment to enable production-only guardrails (refuse to start without a
# vault passphrase, valid license key, and recent revocation check):
# XMEDIA_PROFILE=production
